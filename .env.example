# PostgreSQL connection string. Use Render's Internal Database URL in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Generate a long, random value; do not reuse the example value.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
PROJECT_NAME=Career Compass AI

# Comma-separated allowed frontend origins. Use your actual Vercel production URL.
CORS_ORIGINS=http://localhost:5173

# Optional: enables Gemini-backed replies; omit to use the existing local fallback.
GEMINI_API_KEY=
