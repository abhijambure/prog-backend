# MongoDB Atlas connection string. Never commit the real value.
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster>/<database>?retryWrites=true&w=majority

# Generate a long, random value; do not reuse the example value.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
PROJECT_NAME=Career Compass AI

# Comma-separated allowed frontend origins. Use your actual Vercel production URL.
CORS_ORIGINS=http://localhost:5173,https://YOUR-VERCEL-DOMAIN.vercel.app

# Optional: enables Gemini-backed replies; omit to use the existing local fallback.
GEMINI_API_KEY=
